APP_NAME=ResumeForge API
DEBUG=true
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3000,http://127.0.0.1:3000
# Local development default (recommended)
DATABASE_URL=sqlite+pysqlite:///./dev_resumeforge.db
# Production example:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/resumeforge
JWT_SECRET_KEY=change-this-in-local
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=ResumeForge
SMTP_REPLY_TO=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20

# Optional: Brevo transactional API (works on hosts that block SMTP ports)
# If set, Brevo is preferred and SMTP is used as fallback.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=ResumeForge
BREVO_REPLY_TO=
BREVO_BASE_URL=https://api.brevo.com

AI_PROVIDER_MODE=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_KEEP_ALIVE=5m
AI_REQUEST_TIMEOUT_MS=30000
AI_MAX_RETRIES=1
